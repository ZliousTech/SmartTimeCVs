@model SmartTimeCVs.Web.Core.ViewModels.JobOfferViewModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SmartTimeCVs.Web.SharedResource> Localizer
@{
    Layout = null;
    var companyName = string.IsNullOrEmpty(Model.SenderName) ? "SmartTime CVs" : Model.SenderName;
    var expiryDate = Model.CreatedOn?.AddDays(7).ToString("dd MMM yyyy") ?? DateTime.Now.AddDays(7).ToString("dd MMM yyyy");
}
<!DOCTYPE html>
<html lang="@System.Threading.Thread.CurrentThread.CurrentUICulture.Name" dir="@(System.Threading.Thread.CurrentThread.CurrentUICulture.Name.Contains("ar") ? "rtl" : "ltr")">
<head>
    <meta charset="utf-8" />
    <title>@Localizer["Job Offer"] - @Model.CandidateName</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <style>
        body { 
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; 
            background: #f4f7f6; 
            color: #333; 
        }
        .offer-container { 
            max-width: 800px; 
            margin: 0 auto; 
            padding: 50px 60px; 
            background: #fff;
            line-height: 1.6;
        }
        .header { 
            text-align: center; 
            margin-bottom: 40px; 
        }
        .header h1 { font-weight: bold; letter-spacing: 1px; font-size: 24px; text-decoration: underline; }
        .letter-content { margin-bottom: 35px; font-size: 15px; }
        .letter-content p { margin-bottom: 15px; }
        .letter-content ul { margin-bottom: 15px; margin-top: 10px; }
        .watermark { 
            position: absolute; 
            top: 50%; 
            left: 50%; 
            transform: translate(-50%, -50%) rotate(-45deg); 
            font-size: 8rem; 
            color: rgba(0,0,0,0.03); 
            z-index: 0; 
            white-space: nowrap; 
            pointer-events: none;
        }
        .content-layer {
            position: relative;
            z-index: 1;
        }
        .loader-wrapper {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(255,255,255,0.9); z-index: 9999;
            display: flex; flex-direction: column; justify-content: center; align-items: center;
        }
        .signature-block {
            margin-top: 40px;
        }
        .signature-line {
            width: 250px;
            border-bottom: 1px solid #333;
            margin-bottom: 5px;
            display: inline-block;
        }
    </style>
</head>
<body>
    <div id="loader" class="loader-wrapper">
        <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
            <span class="visually-hidden">Generating PDF...</span>
        </div>
        <h4 class="mt-3 text-primary">@Localizer["Generating PDF, please wait..."]</h4>
    </div>

    <div id="pdf-content" class="offer-container">
        <div class="watermark">@Localizer["Job Offer"]</div>
        
        <div class="content-layer">
            <div class="header">
                <h1>@Localizer["JOB OFFER LETTER"]</h1>
            </div>

            <div class="letter-content">
                <p><strong>@Localizer["Date"]:</strong> @DateTime.Now.ToString("dd MMM yyyy")</p>
                <br/>
                <p><strong>@Localizer["Candidate Name"]:</strong> @Model.CandidateName<br/>
                <strong>@Localizer["Address"]:</strong> @(string.IsNullOrEmpty(Model.CandidateAddress) ? Localizer["N/A"] : Model.CandidateAddress)</p>
                
                <p>@Localizer["Dear"] @Model.CandidateName,</p>
                
                <p>
                    @Localizer["We are pleased to offer you the position of"] <strong>@Model.JobTitle</strong> @Localizer["at"] <strong>@companyName</strong>, 
                    @Localizer["reporting to"] <strong>@(string.IsNullOrEmpty(Model.ManagerName) ? Localizer["Management"] : Model.ManagerName)</strong> @(string.IsNullOrEmpty(Model.Department) ? "" : " / " + Model.Department).
                </p>

                <p>
                    @Localizer["Your employment will commence on"] <strong>@Model.StartDate.ToString("dd MMM yyyy")</strong>. 
                    @Localizer["The compensation package for this position is as follows:"]
                </p>

                <ul>
                    <li><strong>@Localizer["Basic Salary"]:</strong> @Model.OfferedSalary.ToString("N2") @(string.IsNullOrEmpty(Model.Currency) ? "JOD" : Model.Currency) @Localizer["per month"]</li>
                    <li><strong>@Localizer["Allowances (if any)"]:</strong> @(string.IsNullOrEmpty(Model.Allowances) ? Localizer["N/A"] : Model.Allowances)</li>
                    <li><strong>@Localizer["Probation Period"]:</strong> @(string.IsNullOrEmpty(Model.ProbationPeriod) ? Localizer["N/A"] : Model.ProbationPeriod)</li>
                    <li><strong>@Localizer["Working Hours"]:</strong> @(string.IsNullOrEmpty(Model.WorkingHours) ? Localizer["N/A"] : Model.WorkingHours)</li>
                    <li><strong>@Localizer["Other Benefits"]:</strong> @(string.IsNullOrEmpty(Model.Benefits) ? Localizer["N/A"] : Model.Benefits)</li>
                </ul>

                <p>@Localizer["This offer is contingent upon successful completion of all pre-employment requirements and signing the official employment contract."]</p>

                <p>@Localizer["Please confirm your acceptance of this offer by signing below and returning a copy of this letter by"] <strong>@expiryDate</strong>.</p>
                
                <p>@Localizer["We look forward to welcoming you to our team."]</p>
                
                <p>@Localizer["Sincerely,"]</p>
                
                <div class="signature-block">
                    <div class="signature-line"></div><br/>
                    <strong>@(string.IsNullOrEmpty(Model.SenderName) ? "HR Department" : Model.SenderName)</strong><br/>
                    @companyName
                </div>

                <div class="signature-block" style="margin-top: 50px;">
                    <p>@Localizer["Accepted by:"]</p>
                    <br/><br/>
                    <div class="signature-line"></div><br/>
                    <strong>@Model.CandidateName</strong><br/>
                    @Localizer["Date"]: <span class="signature-line" style="width: 150px; border-bottom: 1px solid #333; display: inline-block;"></span>
                </div>
            </div>
        </div>
    </div>

    <script>
        window.onload = function() {
            var element = document.getElementById('pdf-content');
            var isRtl = document.dir === 'rtl';

            var opt = {
              margin:       [0.5, 0.5, 0.5, 0.5], // 0.5 inch margins all around
              filename:     'JobOffer_@(Model.CandidateName?.Replace(" ", "_")).pdf',
              image:        { type: 'jpeg', quality: 1 },
              html2canvas:  { scale: 2, useCORS: true, letterRendering: true, scrollY: 0 },
              jsPDF:        { unit: 'in', format: 'letter', orientation: 'portrait' }
            };

            html2pdf().set(opt).from(element).save().then(function() {
                setTimeout(function(){ 
                    document.getElementById('loader').style.display = 'none';
                    window.close(); 
                }, 1000);
            });
        };
    </script>
</body>
</html>
