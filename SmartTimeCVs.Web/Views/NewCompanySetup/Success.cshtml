@{
    Layout = "_Layout";
    ViewData["Title"] = "Success";
    ViewData["HideSidebars"] = true;
}

<div class="row clearfix">
    <div class="col-lg-12">
        <div class="card shadow-sm text-center p-5">
            <div class="card-body">
                <div class="mb-4">
                    <i class="material-icons theme-main-color" style="font-size: 100px;">check_circle</i>
                </div>
                <h1 class="display-4 theme-main-color"><b>Success!</b></h1>
                <p class="lead text-muted mb-5">Your profile has been completed and saved successfully. You are now part of the company system.</p>
                <div class="mt-4">
                    <p class="text-muted">You can now close this window or go back to the main site.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .theme-main-color { color: #00bcd4; }
</style>
