@model JobApplicationViewModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SmartTimeCVs.Web.SharedResource> Localizer

@{
    Layout = "_Layout";
    ViewData["Title"] = Localizer["Personal Information"];
    ViewData["HideSidebars"] = true;
}

@section Styles {
    <link rel="stylesheet" href="~/theme/assets/css/plugins/bootstrap-select.css" />
    <link rel="stylesheet" href="~/theme/assets/css/plugins/bootstrap-material-datetimepicker.css" />
    <link rel="stylesheet" href="~/lib/font-awesome/css/all.min.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <style>
        .theme-main-color { color: #00bcd4; }
        .card { border-radius: 15px; overflow: hidden; }
        .form-control { border-radius: 20px; border: 1px solid #e0e0e0; padding: 10px 20px; height: 45px; }
        .form-control:focus { border-color: #00bcd4; box-shadow: 0 0 0 0.2rem rgba(0, 188, 212, 0.25); }
        
        /* Select2 Oval Styling */
        .select2-container--default .select2-selection--single {
            border-radius: 20px !important;
            border: 1px solid #e0e0e0 !important;
            height: 45px !important;
            padding: 8px 15px !important;
        }
        .select2-container--default .select2-selection--single .select2-selection__arrow {
            height: 43px !important;
            right: 10px !important;
        }
        .select2-container--default .select2-selection--single .select2-selection__rendered {
            line-height: 28px !important;
            color: #495057 !important;
        }
        
        .btn-info { border-radius: 25px; padding: 10px 30px; background-color: #00bcd4; border: none; }
        .card-inside-title { font-size: 14px; font-weight: bold; color: #555; }
        .image-upload-container { position: relative; width: 120px; height: 120px; margin: 0 auto 20px; }
        .image-preview { width: 100%; height: 100%; border-radius: 50%; border: 3px solid #00bcd4; background-size: cover; background-position: center; }
        .edit-icon { position: absolute; bottom: 0; right: 0; background: #00bcd4; color: white; border-radius: 50%; padding: 8px; cursor: pointer; }

        /* Map Picker */
        .map-picker-wrapper {
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 4px 20px rgba(0,188,212,0.15);
            border: 2px solid #e0f7fa;
            transition: border-color 0.3s;
        }
        .map-picker-wrapper:hover { border-color: #00bcd4; }
        #locationMap { height: 260px; width: 100%; }
        .map-search-bar {
            display: flex;
            gap: 8px;
            margin-bottom: 8px;
        }
        .map-search-bar input {
            flex: 1;
            border-radius: 20px;
            border: 1px solid #e0e0e0;
            padding: 8px 16px;
            height: 40px;
            font-size: 13px;
        }
        .map-search-bar input:focus { outline: none; border-color: #00bcd4; }
        .btn-map-action {
            border-radius: 20px;
            padding: 6px 14px;
            font-size: 13px;
            font-weight: 600;
            border: none;
            cursor: pointer;
            transition: all 0.2s;
            height: 40px;
            white-space: nowrap;
        }
        .btn-map-search { background: #00bcd4; color: #fff; }
        .btn-map-search:hover { background: #0097a7; }
        .btn-map-gps { background: #e0f7fa; color: #00838f; border: 1px solid #b2ebf2; }
        .btn-map-gps:hover { background: #b2ebf2; }
        .map-coords-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: linear-gradient(135deg, #e0f7fa, #f1f8e9);
            border: 1px solid #b2ebf2;
            border-radius: 20px;
            padding: 4px 14px;
            font-size: 12px;
            color: #00695c;
            font-weight: 600;
            margin-top: 6px;
            transition: all 0.3s;
        }
        .map-coords-badge.hidden { opacity: 0; pointer-events: none; }
        .map-pin-pulse {
            position: relative;
            display: inline-block;
        }
        .leaflet-marker-icon { filter: hue-rotate(170deg); }
    </style>
}

<div class="row clearfix">
    <div class="col-lg-12">
        <div class="card shadow">
            <div class="card-header text-center py-4 bg-white">
                <h2 class="theme-main-color mb-0"><b>@Localizer["Personal Information"]</b></h2>
                <p class="text-muted">@Localizer["Please complete your basic information to finish the setup."]</p>
            </div>
            <div class="card-body p-4">
                <form id="profileForm" asp-action="CompleteProfile" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="CompanyId" />
                    <input type="hidden" asp-for="HighSchoolName" />
                    <input type="hidden" asp-for="HighSchoolGraduationYear" />
                    <input type="hidden" asp-for="EnglishLevelId" />
                    <input type="hidden" asp-for="ComputerSkillsLevelId" />
                    <input type="hidden" asp-for="ExpectedSalary" />
                    <input type="hidden" asp-for="ImageUrl" />
                    <input type="hidden" asp-for="SystemUserName" />
                    <input type="hidden" asp-for="SystemPassword" />

                    <div class="row clearfix mb-4 text-center">
                        <div class="col-12">
                            <div class="image-upload-container">
                                <div class="image-preview" id="imagePreview" style="background-image: url('/images/profileImages/@(string.IsNullOrEmpty(Model.ImageUrl) ? "ProfileImagePlaceholder.jpg" : Model.ImageUrl)');"></div>
                                <label class="edit-icon" for="ImageFile">
                                    <i class="fas fa-camera"></i> <span class="text-danger">*</span>
                                    <input type="file" asp-for="ImageFile" accept=".jpg, .jpeg, .png" style="display: none;" onchange="previewImage(this)" />
                                </label>
                            </div>
                            <small class="text-danger d-none" id="imageError">@Localizer["Profile image is required"]</small>
                        </div>
                    </div>

                    <div class="row clearfix">
                        <div class="col-md-6 mb-3">
                            <h2 class="card-inside-title">@Localizer["Full Name"] <span class="text-danger">*</span></h2>
                            <input type="text" class="form-control" asp-for="FullName" required>
                            <span asp-validation-for="FullName" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <h2 class="card-inside-title">@Localizer["Gender"] <span class="text-danger">*</span></h2>
                            <select class="form-control js-select2" asp-for="GenderId" asp-items="ViewBag.GenderList"></select>
                            <span asp-validation-for="GenderId" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row clearfix">
                        <div class="col-md-6 mb-3">
                            <h2 class="card-inside-title">@Localizer["Email"]</h2>
                            <input type="email" class="form-control bg-light" asp-for="Email" readonly>
                        </div>
                        <div class="col-md-6 mb-3">
                            <h2 class="card-inside-title">@Localizer["Nationality"] <span class="text-danger">*</span></h2>
                            <select class="form-control js-select2" asp-for="Nationality" asp-items="ViewBag.NationalityList"></select>
                            <span asp-validation-for="Nationality" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row clearfix">
                        <div class="col-md-6 mb-3">
                            <h2 class="card-inside-title">@Localizer["Date Of Birth"] <span class="text-danger">*</span></h2>
                            <input type="date" class="form-control" asp-for="DateOfBirth" required>
                            <span asp-validation-for="DateOfBirth" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <h2 class="card-inside-title">@Localizer["Place Of Birth"] <span class="text-danger">*</span></h2>
                            <input type="text" class="form-control" asp-for="PlaceOfBirth" required>
                            <span asp-validation-for="PlaceOfBirth" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row clearfix">
                        <div class="col-md-6 mb-3">
                            <h2 class="card-inside-title">@Localizer["Mobile Number"] <span class="text-danger">*</span></h2>
                            <input type="text" class="form-control" asp-for="MobileNumber" required>
                            <span asp-validation-for="MobileNumber" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <h2 class="card-inside-title">@Localizer["National Number"] <span class="text-danger">*</span></h2>
                            <input type="text" class="form-control" asp-for="NationalID" required>
                            <span asp-validation-for="NationalID" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row clearfix">
                        <div class="col-md-6 mb-3">
                            <h2 class="card-inside-title">@Localizer["Marital Status"] <span class="text-danger">*</span></h2>
                            <select class="form-control js-select2" asp-for="MaritalStatusId" asp-items="ViewBag.MaritalStatusList"></select>
                            <span asp-validation-for="MaritalStatusId" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row clearfix mb-4">
                        <div class="col-md-12">
                            <h2 class="card-inside-title">@Localizer["Address"] &amp; @Localizer["Home Location"] <span class="text-danger">*</span></h2>
                            
                            <!-- Address Text -->
                            <input type="text" class="form-control mb-3" asp-for="Address"
                                   placeholder="@Localizer["Your address will be filled automatically when you pick on the map"]"
                                   required id="addressInput">
                            <span asp-validation-for="Address" class="text-danger"></span>

                            <!-- Hidden lat/lng -->
                            <input type="hidden" asp-for="Latitude" id="latInput" />
                            <input type="hidden" asp-for="Longitude" id="lngInput" />

                            <!-- Map Search Bar -->
                            <div class="map-search-bar mt-3">
                                <input type="text" id="mapSearchInput" placeholder="@Localizer["Search for your area..."]" />
                                <button type="button" class="btn-map-action btn-map-search" onclick="searchMapLocation()">
                                    <i class="fas fa-search"></i> @Localizer["Search"]
                                </button>
                                <button type="button" class="btn-map-action btn-map-gps" onclick="useMyLocation()" id="gpsBtn">
                                    <i class="fas fa-crosshairs"></i> @Localizer["My Location"]
                                </button>
                            </div>

                            <!-- Map Container -->
                            <div class="map-picker-wrapper mt-3" style="border-radius: 15px; overflow: hidden; border: 1px solid #e0e0e0; width: 100%;">
                                <div id="locationMap" style="height: 300px; width: 100%;"></div>
                            </div>

                            <!-- Coordinates Badge -->
                            <div class="map-coords-badge hidden mt-2" id="coordsBadge">
                                <i class="fas fa-map-marker-alt" style="color:#00bcd4"></i>
                                <span id="coordsText">--</span>
                            </div>
                        </div>
                    </div>

                    <div class="row clearfix">
                        <div class="col-md-6 mb-3">
                            <h2 class="card-inside-title">@Localizer["Applying For"] <span class="text-danger">*</span></h2>
                            <select class="form-control js-select2" asp-for="ApplyingFor" asp-items="ViewBag.ApplyingForList">
                                <option value="">-- @Localizer["Select Category"] --</option>
                            </select>
                            <span asp-validation-for="ApplyingFor" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <h2 class="card-inside-title">@Localizer["Job Title"] <span class="text-danger">*</span></h2>
                            <select class="form-control js-select2" id="JobTitleSelect" name="JobTitleSelect">
                                <option value="">-- @Localizer["Select Title"] --</option>
                            </select>
                            <input type="hidden" id="JobTitleValue" asp-for="JobTitle" />
                            <span asp-validation-for="JobTitle" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row clearfix mt-4">
                        <div class="col-12 text-center">
                            <button type="submit" class="btn btn-info btn-lg shadow">@Localizer["Save & Finish"]</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="~/js/shared/form-select-validator.js" asp-append-version="true"></script>
    <script>
        function previewImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    $('#imagePreview').css('background-image', 'url(' + e.target.result + ')');
                }
                reader.readAsDataURL(input.files[0]);
            }
        }

        $(document).ready(function () {
            // Re-initialize select2 with original styles/logic
            $('.js-select2').select2({ width: '100%' });

            $('#ApplyingFor').on('change', function () {
                var selectedCategoryId = $(this).val();
                loadJobTitles(selectedCategoryId);
            });

            function loadJobTitles(applyingForId) {
                if (!applyingForId) {
                    $('#JobTitleSelect').empty().append('<option value="">-- @Localizer["Select Title"] --</option>');
                    return;
                }

                $.ajax({
                    url: '/Biography/GetJobTitlesByCategory', // Using absolute path
                    type: 'GET',
                    data: { categoryGuidID: applyingForId },
                    success: function (data) {
                        var jobTitleSelect = $('#JobTitleSelect');
                        jobTitleSelect.empty();
                        jobTitleSelect.append('<option value="">-- @Localizer["Select Title"] --</option>');

                        if (data && data.length > 0) {
                            $.each(data, function (i, item) {
                                jobTitleSelect.append($('<option>', {
                                    value: item.value,
                                    text: item.text
                                }));
                            });
                        }
                        
                        // Set value if already present in hidden field (for edit mode)
                        var existingTitle = $('#JobTitleValue').val();
                        if(existingTitle) {
                             // Try to find the option with that text and select it
                             jobTitleSelect.find('option').each(function(){
                                 if($(this).text() === existingTitle) $(this).prop('selected', true);
                             });
                             jobTitleSelect.trigger('change');
                        }
                    }
                });
            }

            $('#profileForm').on('submit', function (e) {
                e.preventDefault();
                
                // Update hidden JobTitle text before submission
                var selectedJobTitleText = $('#JobTitleSelect option:selected').text();
                $('#JobTitleValue').val(selectedJobTitleText);

                // Validate Image
                var imageFile = $('#ImageFile')[0].files[0];
                var existingImageUrl = $('#ImageUrl').val();
                if (!imageFile && (!existingImageUrl || existingImageUrl === '')) {
                    $('#imageError').removeClass('d-none');
                    $('html, body').animate({ scrollTop: 0 }, 'slow');
                    return false;
                } else {
                    $('#imageError').addClass('d-none');
                }

                var formData = new FormData(this);
                $.ajax({
                    url: $(this).attr('action'),
                    type: 'POST',
                    data: formData,
                    processData: false,
                    contentType: false,
                    success: function (response) {
                        if (response.success) {
                            Swal.fire({
                                icon: 'success',
                                title: '@Localizer["Success"]',
                                text: '@Localizer["Profile completed successfully!"]',
                                confirmButtonText: 'OK'
                            }).then(() => {
                                window.location.href = '/NewCompanySetup/Success';
                            });
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: '@Localizer["Error"]',
                                text: response.message || 'Error saving profile'
                            });
                        }
                    },
                    error: function (xhr, status, error) {
                        Swal.fire({
                            icon: 'error',
                            title: '@Localizer["Error"]',
                            text: 'Server error: ' + (xhr.responseText || error)
                        });
                    }
                });
            });

            // Initial load if category selected
            var initialCat = $('#ApplyingFor').val();
            if(initialCat) loadJobTitles(initialCat);
        });

        // ─── MAP PICKER ───────────────────────────────────────────────
        var map, marker;
        var savedLat = @(Model.Latitude.HasValue ? Model.Latitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture) : "null");
        var savedLng = @(Model.Longitude.HasValue ? Model.Longitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture) : "null");

        var defaultLat = savedLat || 24.7136;
        var defaultLng = savedLng || 46.6753;
        var defaultZoom = savedLat ? 15 : 5;

        function initMap() {
            map = L.map('locationMap').setView([defaultLat, defaultLng], defaultZoom);

            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
                maxZoom: 19
            }).addTo(map);

            // Custom marker icon
            var customIcon = L.divIcon({
                html: '<div style="width:36px;height:36px;background:linear-gradient(135deg,#00bcd4,#0097a7);border-radius:50% 50% 50% 0;transform:rotate(-45deg);box-shadow:0 4px 15px rgba(0,188,212,0.5);border:3px solid white;"></div>',
                className: '',
                iconSize: [36, 36],
                iconAnchor: [18, 36]
            });

            if (savedLat && savedLng) {
                marker = L.marker([savedLat, savedLng], { icon: customIcon, draggable: true }).addTo(map);
                updateCoordsDisplay(savedLat, savedLng);
                marker.on('dragend', function(e) {
                    var pos = e.target.getLatLng();
                    setLocation(pos.lat, pos.lng, customIcon);
                });
            }

            map.on('click', function(e) {
                setLocation(e.latlng.lat, e.latlng.lng, customIcon);
            });
        }

        function setLocation(lat, lng, icon) {
            if (marker) map.removeLayer(marker);
            var customIcon = icon || L.divIcon({
                html: '<div style="width:36px;height:36px;background:linear-gradient(135deg,#00bcd4,#0097a7);border-radius:50% 50% 50% 0;transform:rotate(-45deg);box-shadow:0 4px 15px rgba(0,188,212,0.5);border:3px solid white;"></div>',
                className: '',
                iconSize: [36, 36],
                iconAnchor: [18, 36]
            });
            marker = L.marker([lat, lng], { icon: customIcon, draggable: true }).addTo(map);
            marker.on('dragend', function(e) {
                var pos = e.target.getLatLng();
                setLocation(pos.lat, pos.lng);
            });
            $('#latInput').val(lat.toFixed(7));
            $('#lngInput').val(lng.toFixed(7));
            updateCoordsDisplay(lat, lng);
            reverseGeocode(lat, lng);
        }

        function updateCoordsDisplay(lat, lng) {
            var badge = document.getElementById('coordsBadge');
            badge.classList.remove('hidden');
            document.getElementById('coordsText').textContent =
                parseFloat(lat).toFixed(5) + ', ' + parseFloat(lng).toFixed(5);
        }

        function reverseGeocode(lat, lng) {
            fetch('https://nominatim.openstreetmap.org/reverse?format=json&lat=' + lat + '&lon=' + lng)
                .then(r => r.json())
                .then(data => {
                    if (data && data.display_name) {
                        $('#addressInput').val(data.display_name);
                    }
                }).catch(() => {});
        }

        function searchMapLocation() {
            var query = document.getElementById('mapSearchInput').value.trim();
            if (!query) return;
            fetch('https://nominatim.openstreetmap.org/search?format=json&q=' + encodeURIComponent(query) + '&limit=1')
                .then(r => r.json())
                .then(data => {
                    if (data && data.length > 0) {
                        var lat = parseFloat(data[0].lat);
                        var lng = parseFloat(data[0].lon);
                        map.setView([lat, lng], 15);
                        setLocation(lat, lng);
                    } else {
                        alert('@Localizer["Location not found. Please try a different search."]');
                    }
                });
        }

        document.getElementById('mapSearchInput').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') { e.preventDefault(); searchMapLocation(); }
        });

        function useMyLocation() {
            var btn = document.getElementById('gpsBtn');
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
            btn.disabled = true;
            if (!navigator.geolocation) {
                alert('@Localizer["Geolocation is not supported by your browser."]');
                btn.innerHTML = '<i class="fas fa-crosshairs"></i> @Localizer["My Location"]';
                btn.disabled = false;
                return;
            }
            navigator.geolocation.getCurrentPosition(function(pos) {
                var lat = pos.coords.latitude;
                var lng = pos.coords.longitude;
                map.setView([lat, lng], 16);
                setLocation(lat, lng);
                btn.innerHTML = '<i class="fas fa-check"></i> @Localizer["Located!"]';
                btn.style.background = '#c8e6c9';
                btn.style.color = '#2e7d32';
                setTimeout(function() {
                    btn.innerHTML = '<i class="fas fa-crosshairs"></i> @Localizer["My Location"]';
                    btn.style.background = '';
                    btn.style.color = '';
                    btn.disabled = false;
                }, 2500);
            }, function() {
                alert('@Localizer["Unable to retrieve your location. Please allow location access."]');
                btn.innerHTML = '<i class="fas fa-crosshairs"></i> @Localizer["My Location"]';
                btn.disabled = false;
            });
        }

        // Init map after DOM is ready
        window.addEventListener('load', function() { initMap(); });
    </script>
}
