@model IEnumerable<SmartTimeCVs.Web.Core.Models.ContractType>
@using Microsoft.AspNetCore.Mvc.Localization
@inject Microsoft.Extensions.Localization.IStringLocalizer<SmartTimeCVs.Web.SharedResource> Localizer

@{
    var isRtl = System.Globalization.CultureInfo.CurrentCulture.Name.StartsWith("ar");
    ViewData["Title"] = Localizer["Contract"].Value;
    ViewData["Path"] = $"{(isRtl ? "الرئيسية" : "Home")} / {(isRtl ? "قائمة إعدادات النظام" : "System lookups list")} / {Localizer["Contract"].Value}";
    ViewData["Icon"] = "assignment";
}

<style>
    .lookup-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 20px;
    }
    .lookup-table th, .lookup-table td {
        padding: 15px 20px;
        text-align: left;
        vertical-align: top;
        font-size: 13px;
        color: #555;
        border-bottom: 1px solid #f0f0f0;
        line-height: 1.6;
    }
    .lookup-table th {
        font-weight: 600;
        color: #333;
        background: #fff;
        border-bottom: 2px solid #eee;
    }
    /* Zebra striping - alternating row colors */
    .lookup-table tbody tr:nth-child(odd) {
        background-color: #ECECEC;
    }
    .lookup-table tbody tr:nth-child(even) {
        background-color: #fff;
    }
    .lookup-table tbody tr:hover {
        background-color: #f0f7ff;
    }
    .btn-action-outline {
        color: #00bcd4;
        border: 1px solid #00bcd4;
        background: transparent;
        padding: 6px 15px;
        border-radius: 4px;
        text-transform: uppercase;
        font-size: 11px;
        font-weight: 500;
        display: inline-block;
    }
    .btn-action-outline:hover {
        background: #00bcd4;
        color: #fff;
        text-decoration: none;
    }
    .btn-add-lookup {
        color: #00bcd4;
        border: 1px solid #00bcd4;
        background: transparent;
        padding: 8px 18px;
        border-radius: 4px;
        text-transform: uppercase;
        font-size: 12px;
        font-weight: 500;
        text-decoration: none;
        display: inline-block;
        margin-bottom: 5px;
    }
    .btn-add-lookup:hover {
        background: #00bcd4;
        color: #fff;
        text-decoration: none;
    }
    /* Dropdown */
    .action-dropdown {
        position: relative;
        display: inline-block;
    }
    .action-dropdown .dropdown-menu {
        min-width: 100px;
        padding: 5px 0;
        border-radius: 4px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.15);
        border: 1px solid #e0e0e0;
    }
    .action-dropdown .dropdown-menu a {
        display: block;
        padding: 6px 15px;
        color: #333;
        font-size: 13px;
        text-decoration: none;
    }
    .action-dropdown .dropdown-menu a:hover {
        background-color: #f5f5f5;
    }
    .action-dropdown .dropdown-menu a.text-danger:hover {
        background-color: #fff0f0;
    }
</style>

<div class="row clearfix">
    <div class="col-lg-12">
        <div class="card" style="box-shadow: none;">
            <div class="body">
                <a asp-action="AddContractType" class="btn-add-lookup">@Localizer["ADD CONTRACT"]</a>
                
                <div class="table-responsive">
                    <table class="table lookup-table">
                        <thead>
                            <tr>
                                <th>@Localizer["Actions"]</th>
                                <th>@Localizer["Contract"]</th>
                                <th>@Localizer["Contract For"]</th>
                                <th>@Localizer["Introduction"]</th>
                                <th>@Localizer["Clauses"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Any())
                            {
                                <tr>
                                    <td colspan="5" class="text-center" style="padding: 30px;">
                                        <div class="text-muted">@Localizer["No contracts found. Add a new one to get started."]</div>
                                    </td>
                                </tr>
                            }
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="action-dropdown">
                                            <button class="btn-action-outline dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">@Localizer["Actions"]</button>
                                            <div class="dropdown-menu">
                                                <a href="@Url.Action("AddContractType", new { id = item.Id })">@Localizer["Edit"]</a>
                                                <a href="javascript:void(0)" class="text-danger" onclick="deleteType(@item.Id)">@Localizer["Delete"]</a>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div style="color: #333; margin-bottom: 4px; font-size: 13px;">
                                            @(isRtl ? item.NameNative : item.NameEn)
                                        </div>
                                    </td>
                                    <td>
                                        <div>@item.ContractFor</div>
                                    </td>
                                    <td>
                                        <div>
                                            @(isRtl ? item.DescriptionNative : item.DescriptionEn)
                                        </div>
                                    </td>
                                    <td>
                                        <div style="font-size: 13px;">
                                            @{
                                                var clauseText = isRtl ? item.ClausesNative : item.ClausesEn;
                                                if (!string.IsNullOrWhiteSpace(clauseText))
                                                {
                                                    var clauses = clauseText.Split(new[] { "\\n", "\n", "\r\n" }, StringSplitOptions.RemoveEmptyEntries);
                                                    for (var i = 0; i < clauses.Length; i++)
                                                    {
                                                        <div style="margin-bottom: 8px;">
                                                            <strong>@Localizer["Clause"] @(i+1):</strong> @clauses[i]
                                                        </div>
                                                    }
                                                }
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function deleteType(id) {
            Swal.fire({
                title: '@Localizer["Are you sure?"]',
                text: "@Localizer["You won't be able to revert this!"]",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: '@Localizer["Yes, delete it!"]'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('@Url.Action("DeleteContractType", "Settings")', { id: id }, function (data) {
                        if (data.success) {
                            location.reload();
                        } else {
                            Swal.fire('Error!', data.message, 'error');
                        }
                    });
                }
            });
        }
    </script>
}
