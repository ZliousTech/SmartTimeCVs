@model SmartTimeCVs.Web.Core.Models.DocumentRequirementLookup
@using Microsoft.AspNetCore.Mvc.Localization
@inject Microsoft.Extensions.Localization.IStringLocalizer<SmartTimeCVs.Web.SharedResource> Localizer

@{
    var isNew = Model.Id == 0;
    var isRtl = System.Globalization.CultureInfo.CurrentCulture.Name.StartsWith("ar");
    ViewData["Title"] = isNew ? Localizer["Add Document Requirement"].Value : Localizer["Edit Document Requirement"].Value;
    ViewData["Path"] = $"{(isRtl ? "الرئيسية" : "Home")} / {(isRtl ? "قائمة إعدادات النظام" : "System lookups list")} / {Localizer["Document Requirements"].Value} / {(isNew ? "Add" : "Edit")}";
    ViewData["Icon"] = "insert_drive_file";
}

<style>
    .section-title {
        color: #fca170;
        font-weight: 600;
        margin-bottom: 15px;
        margin-top: 30px;
        text-transform: uppercase;
        font-size: 14px;
    }
    .btn-save {
        background-color: #03a9f4;
        color: #fff;
        border: none;
        padding: 8px 25px;
        border-radius: 3px;
    }
    .btn-cancel {
        background-color: #ff5252;
        color: #fff;
        border: none;
        padding: 8px 25px;
        border-radius: 3px;
        margin-left: 10px;
    }
</style>

<div class="row clearfix">
    <div class="col-lg-12">
        <div class="card">
            <div class="body">
                <form asp-action="SaveDocumentRequirement" method="post">
                    <input type="hidden" asp-for="Id" />
                    
                    <div class="row mb-4">
                        <div class="col-md-6 mb-3">
                            <h2 class="card-inside-title mb-2">@Localizer["Document Requirement (English)"] <span class="text-danger">*</span></h2>
                            <div class="form-group form-float">
                                <input asp-for="NameEn" class="form-control w-100" placeholder="e.g. Police Clearance" required />
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <h2 class="card-inside-title mb-2">@Localizer["Document Requirement (Arabic)"] <span class="text-danger">*</span></h2>
                            <div class="form-group form-float">
                                <input asp-for="NameNative" class="form-control w-100" placeholder="e.g. عدم محكومية" required />
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="form-check mt-3">
                                <input asp-for="IsRequired" class="form-check-input" type="checkbox" id="IsRequired" checked="@(isNew ? "checked" : null)">
                                <label class="form-check-label" for="IsRequired">
                                    @Localizer["Required?"]
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="mt-5 bg-light p-3 border-top">
                        <button type="submit" class="btn btn-save">@Localizer["Save"]</button>
                        <a asp-action="DocumentRequirements" class="btn btn-cancel">@Localizer["Cancel"]</a>
                        @if (!isNew)
                        {
                            <button type="button" class="btn btn-outline-danger float-right" onclick="deleteType(@Model.Id)">@Localizer["Delete"]</button>
                        }
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function deleteType(id) {
            Swal.fire({
                title: '@Localizer["Are you sure?"]',
                text: "@Localizer["You won't be able to revert this!"]",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: '@Localizer["Yes, delete it!"]'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('@Url.Action("DeleteDocumentRequirement", "Settings")', { id: id }, function (data) {
                        if (data.success) {
                            window.location.href = '@Url.Action("DocumentRequirements", "Settings")';
                        } else {
                            Swal.fire('Error!', data.message, 'error');
                        }
                    });
                }
            });
        }
    </script>
}
