@using Microsoft.AspNetCore.Mvc.Localization
@model SmartTimeCVs.Web.Core.Models.Contract
@inject Microsoft.Extensions.Localization.IStringLocalizer<SmartTimeCVs.Web.SharedResource> Localizer

@{
    ViewData["Title"] = @Localizer["Add New Contract"];
    ViewData["ControllerName"] = "Contracts";
    ViewData["Path"] = $"{@Localizer["Contracts"]} / {@Localizer["Add New"]}";
    ViewData["Icon"] = "gavel";
}

@section Styles {
    <style>
        .select2-container .select2-selection--single {
            height: 38px !important;
            border: 1px solid #E3E3E3 !important;
            border-radius: 30px !important;
            outline: none !important;
        }
        .select2-container--default .select2-selection--single .select2-selection__rendered {
            line-height: 38px !important;
            padding-left: 15px;
            padding-right: 15px;
        }
        .select2-container--default .select2-selection--single .select2-selection__arrow {
            height: 38px !important;
        }
        /* Hide any injected select styling to avoid duplicates */
        .nice-select.form-control { display: none !important; }
    </style>
}

<div class="row clearfix">
    <div class="col-lg-12 col-md-12 col-sm-12">
        <div class="card">
            <div class="header">
                <h2><strong>@Localizer["Contract"]</strong> @Localizer["Details"]</h2>
            </div>
            <div class="body">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    
                    <div class="row clearfix mb-4">
                        <div class="col-sm-12">
                            <label class="font-weight-bold" style="color: #00bcd4;">@Localizer["Auto Fill From Job Applications"]</label>
                            <select id="jobApplicationSelect" name="JobApplicationId" class="form-control" style="width: 100%;">
                                <option value="">-- @Localizer["Select Candidate"] --</option>
                            </select>
                            <small class="form-text text-muted">@Localizer["Auto Fill Help Text"]</small>
                        </div>
                    </div>

                    <h6 class="mt-4 text-info">@Localizer["Employer Info"]</h6>
                    <hr />
                    <div class="row clearfix">
                        <div class="col-sm-4">
                            <div class="form-group">
                                <label asp-for="SchoolName">@Localizer["School Name"]</label>
                                <input asp-for="SchoolName" class="form-control" required />
                                <span asp-validation-for="SchoolName" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="form-group">
                                <label asp-for="RepresentativeName">@Localizer["Representative Name"]</label>
                                <input asp-for="RepresentativeName" class="form-control" placeholder="@Localizer["Representative Name Placeholder"]" required />
                                <span asp-validation-for="RepresentativeName" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="form-group">
                                <label asp-for="RepresentativeTitle">@Localizer["Representative Title"]</label>
                                <input asp-for="RepresentativeTitle" class="form-control" placeholder="@Localizer["Representative Title Placeholder"]" required />
                                <span asp-validation-for="RepresentativeTitle" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <h6 class="mt-4 text-info">@Localizer["Employee Info"]</h6>
                    <hr />
                    <div class="row clearfix">
                        <div class="col-sm-4">
                            <div class="form-group">
                                <label asp-for="EmployeeName">@Localizer["Employee Name"]</label>
                                <input asp-for="EmployeeName" class="form-control" id="employeeName" required />
                                <span asp-validation-for="EmployeeName" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="form-group">
                                <label asp-for="EmployeeNationalId">@Localizer["National ID"]</label>
                                <input asp-for="EmployeeNationalId" class="form-control" id="employeeNationalId" required />
                                <span asp-validation-for="EmployeeNationalId" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="form-group">
                                <label asp-for="EmployeeAddress">@Localizer["Address"]</label>
                                <input asp-for="EmployeeAddress" class="form-control" id="employeeAddress" required />
                                <span asp-validation-for="EmployeeAddress" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <h6 class="mt-4 text-info">@Localizer["Contract Details"]</h6>
                    <hr />
                    <div class="row clearfix">
                        <div class="col-sm-6">
                            <div class="form-group">
                                <label asp-for="JobTitle">@Localizer["Job Title"]</label>
                                <input asp-for="JobTitle" class="form-control" id="jobTitle" required />
                                <span asp-validation-for="JobTitle" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="form-group">
                                <label asp-for="ContractDuration">@Localizer["Contract Duration"]</label>
                                <input asp-for="ContractDuration" class="form-control" required />
                                <span asp-validation-for="ContractDuration" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="form-group">
                                <label asp-for="StartDate">@Localizer["Start Date"]</label>
                                <input asp-for="StartDate" type="date" class="form-control" required />
                                <span asp-validation-for="StartDate" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="form-group">
                                <label asp-for="EndDate">@Localizer["End Date"]</label>
                                <input asp-for="EndDate" type="date" class="form-control" required />
                                <span asp-validation-for="EndDate" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="form-group">
                                <label asp-for="ProbationPeriod">@Localizer["Probation Period"]</label>
                                <input asp-for="ProbationPeriod" class="form-control" id="ProbationPeriod" required />
                                <span asp-validation-for="ProbationPeriod" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="form-group">
                                <label asp-for="MonthlySalary">@Localizer["Monthly Salary"]</label>
                                <input asp-for="MonthlySalary" type="number" step="0.01" class="form-control" id="monthlySalary" required />
                                <span asp-validation-for="MonthlySalary" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="form-group">
                                <label asp-for="SalaryPaymentDay">@Localizer["Salary Payment Day"]</label>
                                <input asp-for="SalaryPaymentDay" type="number" class="form-control" required />
                                <span asp-validation-for="SalaryPaymentDay" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row clearfix mt-4">
                        <div class="col-sm-12 text-right">
                            <button type="submit" class="btn btn-primary btn-round">@Localizer["Save"]</button>
                            <a asp-action="Index" class="btn btn-default btn-round btn-simple">@Localizer["Cancel"]</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function() {
            // Load candidates
            var select = $('#jobApplicationSelect');
            
            // Initialize select2
            select.select2({
                width: '100%',
                placeholder: '-- @Localizer["Select Candidate"] --',
                allowClear: true
            });
            $.get('@Url.Action("GetJobApplications", "Contracts")', function(data) {
                $.each(data, function(index, item) {
                    select.append($('<option/>', {
                        value: item.id,
                        text: item.fullName + ' - ' + item.nationalId,
                        'data-fullname': item.fullName,
                        'data-nationalid': item.nationalId,
                        'data-address': item.address,
                        'data-jobtitle': item.jobTitle,
                        'data-salary': item.expectedSalary,
                        'data-probation': item.probationPeriod
                    }));
                });
                select.trigger('change');
            });

            // Bind change event
            select.on('change', function() {
                var selectedOption = $(this).find('option:selected');
                if ($(this).val()) {
                    $('#employeeName').val(selectedOption.data('fullname'));
                    $('#employeeNationalId').val(selectedOption.data('nationalid'));
                    $('#employeeAddress').val(selectedOption.data('address'));
                    $('#jobTitle').val(selectedOption.data('jobtitle'));
                    $('#monthlySalary').val(selectedOption.data('salary'));
                    if(selectedOption.data('probation')) {
                        $('#ProbationPeriod').val(selectedOption.data('probation'));
                    }
                }
            });
        });
    </script>
}
