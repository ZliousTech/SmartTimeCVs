@using Microsoft.AspNetCore.Mvc.Localization
@model SmartTimeCVs.Web.Core.Models.Contract
@inject Microsoft.Extensions.Localization.IStringLocalizer<SmartTimeCVs.Web.SharedResource> Localizer
@{
    var currentCulture = System.Globalization.CultureInfo.CurrentCulture;
    var isRtl = currentCulture.TextInfo.IsRightToLeft;
    var alignClass = isRtl ? "text-right" : "text-left";
    var directionStr = isRtl ? "rtl" : "ltr";

    ViewData["Title"] = Localizer["Print Contract"];
    ViewData["ControllerName"] = "Contracts";
    ViewData["Path"] = $"{Localizer["Contracts"]} / {Localizer["Print Contract"]}";
    ViewData["Icon"] = "print";
}

@section Styles {
    <style>
        .contract-document {
            font-family: 'Arial', sans-serif;
            font-size: 18px;
            line-height: 2.0;
            color: #000;
            padding: 50px;
            background: #fff;
            direction: @directionStr;
            text-align: @(isRtl ? "right" : "left");
        }
        
        .contract-document h2 {
            text-align: center;
            font-size: 28px;
            font-weight: bold;
            margin-bottom: 35px;
            text-decoration: underline;
        }

        .contract-document h4 {
            font-size: 22px;
            font-weight: bold;
            margin-top: 30px;
            margin-bottom: 20px;
            color: #222;
        }

        .contract-document p {
            margin-bottom: 18px;
            text-align: justify;
        }

        .contract-document ul {
            margin-right: 25px;
            margin-bottom: 18px;
        }

        .contract-document li {
            margin-bottom: 10px;
        }

        .contract-document .signature-area {
            margin-top: 50px;
        }

        .contract-document .signature-box {
            display: inline-block;
            width: 45%;
            text-align: @(isRtl ? "right" : "left");
        }

        .ml-2, .mr-2 {
            margin-inline-start: 0.5rem;
        }

        @@media print {
            body {
                background: #fff;
            }
            #leftsidebar, .navbar, .page-loader-wrapper, footer, .btn-print, .breadcrumb, .card-header {
                display: none !important;
            }
            .content {
                margin: 0 !important;
                padding: 0 !important;
            }
            .card {
                border: none !important;
                box-shadow: none !important;
            }
            .contract-document {
                padding: 0;
            }
        }
    </style>
}

<div class="row clearfix">
    <div class="col-lg-12 col-md-12 col-sm-12">
        <div class="card">
            <div class="card-header @alignClass">
                <button onclick="window.print();" class="btn btn-primary btn-round btn-print">
                    <i class="material-icons">print</i> @Localizer["Print Document"]
                </button>
                <button onclick="downloadPDF();" class="btn btn-info btn-round btn-print @(isRtl ? "mr-2" : "ml-2")">
                    <i class="material-icons">picture_as_pdf</i> @Localizer["Download PDF"]
                </button>
                <button onclick="sendEmail();" class="btn btn-success btn-round btn-print @(isRtl ? "mr-2" : "ml-2")">
                    <i class="material-icons">email</i> @Localizer["Email Contract"]
                </button>
                <a asp-action="Index" class="btn btn-default btn-round btn-print @(isRtl ? "mr-2" : "ml-2")">@Localizer["Back"]</a>
            </div>
            <div class="body">
                <div class="contract-document">
                    <h2>@Localizer["Work Contract"]</h2>
                    
                    <p>
                        @Localizer["It is on day"] <strong>@Model.CreatedOn?.ToString("dddd", currentCulture)</strong> 
                        @Localizer["Corresponding to"] <strong>@Model.CreatedOn?.ToString("dd / MM / yyyy")</strong>
                    </p>

                    <p>@Localizer["Agreement has been made between:"]</p>

                    <p>
                        @Localizer["First Party:"] <strong>@Model.CompanyName</strong><br />
                        @Localizer["Represented by Mr/Ms:"] <strong>@Model.RepresentativeName</strong> @Localizer["in his capacity as"] <strong>@Model.RepresentativeTitle</strong><br />
                        @Localizer["Hereinafter referred to as the First Party"]
                    </p>

                    <p>
                        @Localizer["Second Party: Mr/Ms:"] <strong>@Model.EmployeeName</strong><br />
                        @Localizer["National ID:"] <strong>@Model.EmployeeNationalId</strong><br />
                        @Localizer["Address:"] <strong>@Model.EmployeeAddress</strong><br />
                        @Localizer["Hereinafter referred to as the Second Party"]
                    </p>

                    <h4>@Localizer["Preamble:"]</h4>
                    @if (Model.ContractType != null && (!string.IsNullOrWhiteSpace(Model.ContractType.DescriptionNative) || !string.IsNullOrWhiteSpace(Model.ContractType.DescriptionEn)))
                    {
                        var isRtlCulture = currentCulture.Name.StartsWith("ar");
                        var preambleText = isRtlCulture && !string.IsNullOrWhiteSpace(Model.ContractType.DescriptionNative) 
                            ? Model.ContractType.DescriptionNative 
                            : Model.ContractType.DescriptionEn;
                            
                        <p style="white-space: pre-wrap;">@preambleText</p>
                    }
                    else
                    {
                        <p>
                            @Localizer["Whereas the First Party wishes to utilize the services of the Second Party in the position of"] (<strong>@Model.JobTitle</strong>) @Localizer["at"] @Model.CompanyName، @Localizer["and the Second Party has agreed to work according to the terms and conditions outlined in this contract, the following has been agreed upon:"]
                        </p>
                    }

                    @if (Model.ContractType != null && (!string.IsNullOrWhiteSpace(Model.ContractType.ClausesNative) || !string.IsNullOrWhiteSpace(Model.ContractType.ClausesEn)))
                    {
                        var isRtlCulture = currentCulture.Name.StartsWith("ar");
                        var clausesText = isRtlCulture && !string.IsNullOrWhiteSpace(Model.ContractType.ClausesNative) 
                            ? Model.ContractType.ClausesNative 
                            : Model.ContractType.ClausesEn;

                        if (!string.IsNullOrWhiteSpace(clausesText))
                        {
                            if (clausesText.TrimStart().StartsWith("[")) 
                            {
                                try 
                                {
                                    var clausesDocs = System.Text.Json.JsonSerializer.Deserialize<List<dynamic>>(clausesText);
                                    if (clausesDocs != null) 
                                    {
                                        for (var i = 0; i < clausesDocs.Count; i++)
                                        {
                                            var titleStr = Convert.ToString(clausesDocs[i].GetProperty("Title").GetString());
                                            var contentStr = Convert.ToString(clausesDocs[i].GetProperty("Content").GetString());
                                            
                                            var displayTitle = !string.IsNullOrWhiteSpace(titleStr) ? titleStr : (isRtlCulture ? $"ثانياً: البند {i + 1}" : $"Clause {i + 1}");
                                            
                                            <h4>@displayTitle</h4>
                                            <p style="white-space: pre-wrap;">@contentStr</p>
                                        }
                                    }
                                } 
                                catch 
                                {
                                    // Fallback if parsing fails for some reason
                                    var clauses = clausesText.Split(new[] { "\\n", "\n", "\r\n" }, StringSplitOptions.RemoveEmptyEntries);
                                    for (var i = 0; i < clauses.Length; i++)
                                    {
                                        <h4>@Localizer["Clause"] @(i + 1)</h4>
                                        <p>@clauses[i]</p>
                                    }
                                }
                            }
                            else 
                            {
                                // Old format fallback
                                var clauses = clausesText.Split(new[] { "\\n", "\n", "\r\n" }, StringSplitOptions.RemoveEmptyEntries);
                                for (var i = 0; i < clauses.Length; i++)
                                {
                                    <h4>@Localizer["Clause"] @(i + 1)</h4>
                                    <p>@clauses[i]</p>
                                }
                            }
                        }
                    }
                    else
                    {
                        @* Fallback to displaying a message if there are no clauses attached, though this shouldn't happen usually *@
                        <p class="text-muted">@Localizer["No additional clauses specified for this contract type."]</p>
                    }

                    <div class="row signature-area">
                        <div class="col-md-6 @alignClass">
                            <p><strong>@Localizer["First Party Signature"] (@Model.CompanyName):</strong></p>
                            <p>@Localizer["Name:"] <strong>@Model.RepresentativeName</strong></p>
                            <p>@Localizer["Signature:"] …………………………</p>
                        </div>
                        <div class="col-md-6 @alignClass">
                            <p><strong>@Localizer["Second Party Signature"] (@Localizer["Employee/Teacher"]):</strong></p>
                            <p>@Localizer["Name:"] <strong>@Model.EmployeeName</strong></p>
                            <p>@Localizer["Signature:"] …………………………</p>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <script>
        function downloadPDF() {
            var element = document.querySelector('.contract-document');
            var EmployeeName = '@Model.EmployeeName';
            
            var opt = {
                margin:       0.5,
                filename:     '@Localizer["Contract"]_' + EmployeeName + '.pdf',
                image:        { type: 'jpeg', quality: 0.98 },
                html2canvas:  { scale: 2, useCORS: true },
                jsPDF:        { unit: 'in', format: 'a4', orientation: 'portrait' }
            };

            // Temporarily disable any max-height/overflow or padding issues if needed
            var originalStyle = element.style.cssText;
            element.style.padding = '20px'; // Less padding for PDF specific so it fits well
            
            html2pdf().set(opt).from(element).save().then(function() {
                element.style.cssText = originalStyle;
            });
        }

        function sendEmail() {
            var element = document.querySelector('.contract-document');
            var EmployeeName = '@Model.EmployeeName';
            var contractId = '@Model.Id';
            
            var opt = {
                margin:       0.5,
                filename:     '@Localizer["Contract"]_' + EmployeeName + '.pdf',
                image:        { type: 'jpeg', quality: 0.98 },
                html2canvas:  { scale: 2, useCORS: true },
                jsPDF:        { unit: 'in', format: 'a4', orientation: 'portrait' }
            };

            var originalStyle = element.style.cssText;
            element.style.padding = '20px';
            
            Swal.fire({
                title: '@Localizer["Sending..."]',
                allowEscapeKey: false,
                allowOutsideClick: false,
                showConfirmButton: false,
                didOpen: () => {
                    Swal.showLoading();
                }
            });

            html2pdf().set(opt).from(element).output('blob').then(function(pdfBlob) {
                element.style.cssText = originalStyle;
                
                var formData = new FormData();
                formData.append('contractId', contractId);
                formData.append('pdfFile', pdfBlob, opt.filename);
                
                fetch('/Contracts/SendContractEmail', {
                    method: 'POST',
                    body: formData
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        Swal.fire('@Localizer["Success!"]', data.message, 'success');
                    } else {
                        Swal.fire('@Localizer["Error"]', data.message, 'error');
                    }
                })
                .catch(error => {
                    Swal.fire('@Localizer["Error"]', 'An error occurred while sending the email.', 'error');
                });
            });
        }
    </script>
}
