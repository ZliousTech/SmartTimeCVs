@using Microsoft.AspNetCore.Mvc.Localization
@model SmartTimeCVs.Web.Core.Models.Contract
@inject Microsoft.Extensions.Localization.IStringLocalizer<SmartTimeCVs.Web.SharedResource> Localizer
@{
    var currentCulture = System.Globalization.CultureInfo.CurrentCulture;
    var isRtl = currentCulture.TextInfo.IsRightToLeft;
    var alignClass = isRtl ? "text-right" : "text-left";
    var directionStr = isRtl ? "rtl" : "ltr";

    ViewData["Title"] = Localizer["Print Contract"];
    ViewData["ControllerName"] = "Contracts";
    ViewData["Path"] = $"{Localizer["Contracts"]} / {Localizer["Print Contract"]}";
    ViewData["Icon"] = "print";
}

@section Styles {
    <style>
        .contract-document {
            font-family: 'Arial', sans-serif;
            font-size: 18px;
            line-height: 2.0;
            color: #000;
            padding: 50px;
            background: #fff;
            direction: @directionStr;
            text-align: @(isRtl ? "right" : "left");
        }
        
        .contract-document h2 {
            text-align: center;
            font-size: 28px;
            font-weight: bold;
            margin-bottom: 35px;
            text-decoration: underline;
        }

        .contract-document h4 {
            font-size: 22px;
            font-weight: bold;
            margin-top: 30px;
            margin-bottom: 20px;
            color: #222;
        }

        .contract-document p {
            margin-bottom: 18px;
            text-align: justify;
        }

        .contract-document ul {
            margin-right: 25px;
            margin-bottom: 18px;
        }

        .contract-document li {
            margin-bottom: 10px;
        }

        .contract-document .signature-area {
            margin-top: 50px;
        }

        .contract-document .signature-box {
            display: inline-block;
            width: 45%;
            text-align: @(isRtl ? "right" : "left");
        }

        .ml-2, .mr-2 {
            margin-inline-start: 0.5rem;
        }

        @@media print {
            body {
                background: #fff;
            }
            #leftsidebar, .navbar, .page-loader-wrapper, footer, .btn-print, .breadcrumb, .card-header {
                display: none !important;
            }
            .content {
                margin: 0 !important;
                padding: 0 !important;
            }
            .card {
                border: none !important;
                box-shadow: none !important;
            }
            .contract-document {
                padding: 0;
            }
        }
    </style>
}

<div class="row clearfix">
    <div class="col-lg-12 col-md-12 col-sm-12">
        <div class="card">
            <div class="card-header @alignClass">
                <button onclick="window.print();" class="btn btn-primary btn-round btn-print">
                    <i class="material-icons">print</i> @Localizer["Print Document"]
                </button>
                <button onclick="downloadPDF();" class="btn btn-info btn-round btn-print @(isRtl ? "mr-2" : "ml-2")">
                    <i class="material-icons">picture_as_pdf</i> @Localizer["Download PDF"]
                </button>
                <button onclick="sendEmail();" class="btn btn-success btn-round btn-print @(isRtl ? "mr-2" : "ml-2")">
                    <i class="material-icons">email</i> @Localizer["Email Contract"]
                </button>
                <a asp-action="Index" class="btn btn-default btn-round btn-print @(isRtl ? "mr-2" : "ml-2")">@Localizer["Back"]</a>
            </div>
            <div class="body">
                <div class="contract-document">
                    <h2>@Localizer["Work Contract"]</h2>
                    
                    <p>
                        @Localizer["It is on day"] <strong>@Model.CreatedOn?.ToString("dddd", currentCulture)</strong> 
                        @Localizer["Corresponding to"] <strong>@Model.CreatedOn?.ToString("dd / MM / yyyy")</strong>
                    </p>

                    <p>@Localizer["Agreement has been made between:"]</p>

                    <p>
                        @Localizer["First Party:"] <strong>@Model.SchoolName</strong><br />
                        @Localizer["Represented by Mr/Ms:"] <strong>@Model.RepresentativeName</strong> @Localizer["in his capacity as"] <strong>@Model.RepresentativeTitle</strong><br />
                        @Localizer["Hereinafter referred to as the First Party"]
                    </p>

                    <p>
                        @Localizer["Second Party: Mr/Ms:"] <strong>@Model.EmployeeName</strong><br />
                        @Localizer["National ID:"] <strong>@Model.EmployeeNationalId</strong><br />
                        @Localizer["Address:"] <strong>@Model.EmployeeAddress</strong><br />
                        @Localizer["Hereinafter referred to as the Second Party"]
                    </p>

                    <h4>@Localizer["Preamble:"]</h4>
                    <p>
                        @Localizer["Whereas the First Party wishes to utilize the services of the Second Party in the position of"] (<strong>@Model.JobTitle</strong>) @Localizer["at"] @Model.SchoolName، @Localizer["and the Second Party has agreed to work according to the terms and conditions outlined in this contract, the following has been agreed upon:"]
                    </p>

                    <h4>@Localizer["Clause One: Contract Subject"]</h4>
                    <p>
                        @Localizer["The Second Party works for the First Party in the position of"] (<strong>@Model.JobTitle</strong>) @Localizer["and is committed to performing the specified job duties according to the school policy and internal regulations."]
                    </p>

                    <h4>@Localizer["Clause Two: Contract Duration"]</h4>
                    <p>
                        @Localizer["The duration of this contract is"] (<strong>@Model.ContractDuration</strong>) @Localizer["starting from the date"] <strong>@Model.StartDate.ToString("dd / MM / yyyy")</strong> @Localizer["and ending on"] <strong>@Model.EndDate.ToString("dd / MM / yyyy")</strong>، @Localizer["and will be automatically renewed unless one of the parties notifies the other of non-renewal at least one month before the end date."]
                    </p>

                    <h4>@Localizer["Clause Three: Probation Period"]</h4>
                    <p>
                        @Localizer["The Second Party is subject to a probation period of"] (<strong>@Model.ProbationPeriod</strong>) @Localizer["from the date of starting work, and the First Party has the right to terminate the contract during this period without prior notice if incompetence is proven."]
                    </p>

                    <h4>@Localizer["Clause Four: Salary and Allowances"]</h4>
                    <p>
                        @Localizer["Monthly Salary:"] (<strong>@Model.MonthlySalary</strong>) @Localizer["Currency Name"].<br />
                        @Localizer["The salary will be paid at the latest on day"] (<strong>@Model.SalaryPaymentDay</strong>) @Localizer["of each month."]<br />
                        @Localizer["Any incentives or bonuses will be according to the school policy and performance evaluation."]
                    </p>

                    <h4>@Localizer["Clause Five: Working Hours"]</h4>
                    <p>
                        @Localizer["The Second Party is committed to the working hours specified by the school administration according to the academic schedule, with commitment to attendance and departure at official times."]
                    </p>

                    <h4>@Localizer["Clause Six: Vacations"]</h4>
                    <p>
                        @Localizer["The Second Party is entitled to annual and official holidays according to the local Labor Law and the school's internal regulations."]
                    </p>

                    <h4>@Localizer["Clause Seven: Professional Obligations"]</h4>
                    <ul>
                        <li>@Localizer["Commitment to the school's policy and educational values."]</li>
                        <li>@Localizer["Maintaining the confidentiality of information related to students and the school."]</li>
                        <li>@Localizer["Commitment to a decent appearance and professional behavior."]</li>
                        <li>@Localizer["Participating in school activities and professional training upon request."]</li>
                    </ul>

                    <h4>@Localizer["Clause Eight: Contract Termination"]</h4>
                    <p>
                        @Localizer["Either party may terminate the contract with a written notice at least one month in advance, with a commitment to hand over all school-related documents and belongings."]
                    </p>

                    <h4>@Localizer["Clause Nine: General Provisions"]</h4>
                    <p>
                        @Localizer["This contract is subject to the provisions of the local Labor Law."]<br />
                        @Localizer["Any dispute will be resolved amicably, and in case of impossibility, jurisdiction will be to the local courts."]
                    </p>

                    <div class="row signature-area">
                        <div class="col-md-6 @alignClass">
                            <p><strong>@Localizer["First Party Signature"] (@Model.SchoolName):</strong></p>
                            <p>@Localizer["Name:"] <strong>@Model.RepresentativeName</strong></p>
                            <p>@Localizer["Signature:"] …………………………</p>
                        </div>
                        <div class="col-md-6 @alignClass">
                            <p><strong>@Localizer["Second Party Signature"] (@Localizer["Employee/Teacher"]):</strong></p>
                            <p>@Localizer["Name:"] <strong>@Model.EmployeeName</strong></p>
                            <p>@Localizer["Signature:"] …………………………</p>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <script>
        function downloadPDF() {
            var element = document.querySelector('.contract-document');
            var EmployeeName = '@Model.EmployeeName';
            
            var opt = {
                margin:       0.5,
                filename:     '@Localizer["Contract"]_' + EmployeeName + '.pdf',
                image:        { type: 'jpeg', quality: 0.98 },
                html2canvas:  { scale: 2, useCORS: true },
                jsPDF:        { unit: 'in', format: 'a4', orientation: 'portrait' }
            };

            // Temporarily disable any max-height/overflow or padding issues if needed
            var originalStyle = element.style.cssText;
            element.style.padding = '20px'; // Less padding for PDF specific so it fits well
            
            html2pdf().set(opt).from(element).save().then(function() {
                element.style.cssText = originalStyle;
            });
        }

        function sendEmail() {
            var element = document.querySelector('.contract-document');
            var EmployeeName = '@Model.EmployeeName';
            var contractId = '@Model.Id';
            
            var opt = {
                margin:       0.5,
                filename:     '@Localizer["Contract"]_' + EmployeeName + '.pdf',
                image:        { type: 'jpeg', quality: 0.98 },
                html2canvas:  { scale: 2, useCORS: true },
                jsPDF:        { unit: 'in', format: 'a4', orientation: 'portrait' }
            };

            var originalStyle = element.style.cssText;
            element.style.padding = '20px';
            
            Swal.fire({
                title: '@Localizer["Sending..."]',
                allowEscapeKey: false,
                allowOutsideClick: false,
                showConfirmButton: false,
                didOpen: () => {
                    Swal.showLoading();
                }
            });

            html2pdf().set(opt).from(element).output('blob').then(function(pdfBlob) {
                element.style.cssText = originalStyle;
                
                var formData = new FormData();
                formData.append('contractId', contractId);
                formData.append('pdfFile', pdfBlob, opt.filename);
                
                fetch('/Contracts/SendContractEmail', {
                    method: 'POST',
                    body: formData
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        Swal.fire('@Localizer["Success!"]', data.message, 'success');
                    } else {
                        Swal.fire('@Localizer["Error"]', data.message, 'error');
                    }
                })
                .catch(error => {
                    Swal.fire('@Localizer["Error"]', 'An error occurred while sending the email.', 'error');
                });
            });
        }
    </script>
}
