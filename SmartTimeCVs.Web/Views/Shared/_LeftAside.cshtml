@using SmartTimeCVs.Web
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> Localizer

@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    var activeKey = $"{controller}-{action}";
}

<aside id="leftsidebar" class="sidebar">
	<div class="menu">
		<ul class="list">
			<li>
				<div class="user-info">
					<div class="image">
						<a href="profile.html">
							<img src="~/theme/assets/imges/Loading.svg" alt="User">
						</a>
					</div>
					<div class="detail">
						<h4></h4>
						<small></small>
					</div>
					<a href="events.html" title="Events"><i class="zmdi zmdi-calendar"></i></a>
					<a href="mail-inbox.html" title="Inbox"><i class="zmdi zmdi-email"></i></a>
					<a href="contact.html" title="Contact List"><i class="zmdi zmdi-account-box-phone"></i></a>
					<a href="chat.html" title="Chat App"><i class="zmdi zmdi-comments"></i></a>
					<a href="sign-in.html" title="Sign out"><i class="zmdi zmdi-power"></i></a>
				</div>
			</li>
			<li active-when="JobApplication, JobApplication-ShortListed, JobApplication-Excluded, JobApplication-Holding">
				<a href="javascript:void(0);" class="menu-toggle">
					<i class="material-icons">description</i><span>CVs</span>
				</a>
				<ul class="ml-menu">
					<li active-when="JobApplication">
						<a asp-controller="JobApplication" asp-action="Index">Job Application</a>
					</li>
					<li active-when="JobApplication-ShortListed">
						<a asp-controller="JobApplication" asp-action="ShortListedIndex">ShortListed</a>
					</li>
					<li active-when="JobApplication-Excluded">
						<a asp-controller="JobApplication" asp-action="ExcludedIndex">Excluded</a>
					</li>
					<li active-when="JobApplication-Holding">
						<a asp-controller="JobApplication" asp-action="HoldingIndex">Holding</a>
					</li>
				</ul>
			</li>

			<li active-when="Interview, Interview-Result, Interview-TestResult, Interview-FinalResult">
				<a href="javascript:void(0);" class="menu-toggle">
					<i class="material-icons">event</i><span>@Localizer["Schedules"]</span>
				</a>
				<ul class="ml-menu">
					<li active-when="Interview">
						<a asp-controller="Interview" asp-action="Index">@Localizer["InterviewAndTestSchedules"]</a>
					</li>
					<li active-when="Interview-Result">
						<a asp-controller="Interview" asp-action="InterviewResults">@Localizer["InterviewResults"]</a>
					</li>
					<li active-when="Interview-TestResult">
						<a asp-controller="Interview" asp-action="TestResults">@Localizer["TestResults"]</a>
					</li>
					<li active-when="Interview-FinalResult">
						<a asp-controller="Interview" asp-action="FinalResults">@Localizer["FinalResults"]</a>
					</li>
				</ul>
			</li>
			<li active-when="Contracts">
				<a href="javascript:void(0);" class="menu-toggle">
					<i class="material-icons">gavel</i><span>@Localizer["Contracts"]</span>
				</a>
				<ul class="ml-menu">
					<li active-when="Contracts-Index, Contracts-Create">
						<a asp-controller="Contracts" asp-action="Index">@Localizer["Contract Organization"]</a>
					</li>
				</ul>
			</li>
            <li active-when="JobApplication-NewcomersIndex, JobApplication-NewcomerArchive, JobApplication-NewcomersIndexArchive">
                <a href="javascript:void(0);" class="menu-toggle">
                    <i class="material-icons">people</i><span>@Localizer["Newcomers"]</span>
                </a>
                <ul class="ml-menu">
                    <li active-when="JobApplication-NewcomersIndex">
                        <a asp-controller="JobApplication" asp-action="NewcomersIndex">@Localizer["PersonalInformation"]</a>
                    </li>
                    <li active-when="JobApplication-NewcomersIndexArchive">
                        <a asp-controller="JobApplication" asp-action="NewcomersIndexArchive">@Localizer["Archive"]</a>
                    </li>
                </ul>
            </li>
			<li active-when="Settings, Settings-GenderTypes, Settings-LevelTypes, Settings-MaritalStatusTypes, Settings-ContractCategories, Settings-ContractTypes">
				<a href="javascript:void(0);" class="menu-toggle">
					<i class="material-icons">settings</i><span>@Localizer["Settings"]</span>
				</a>
				<ul class="ml-menu">
					<li active-when="Settings-ManageLookups">
						<a asp-controller="Settings" asp-action="ManageLookups">@Localizer["Manage Lookups"]</a>
					</li>
				</ul>
			</li>
		</ul>
	</div>
</aside>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var activeKey = '@activeKey';

        // Find all li elements with active-when attribute
        document.querySelectorAll('#leftsidebar li[active-when]').forEach(function (li) {
            var keys = li.getAttribute('active-when').split(',').map(function (k) { return k.trim(); });

            if (keys.indexOf(activeKey) !== -1) {
                li.classList.add('active');

                // If this is a sub-item, also expand the parent menu
                var parentUl = li.closest('.ml-menu');
                if (parentUl) {
                    parentUl.style.display = 'block';
                    var parentLi = parentUl.closest('li[active-when]');
                    if (parentLi) {
                        parentLi.classList.add('active', 'toggled');
                    }
                }

                // Bold the active link
                var link = li.querySelector('a');
                if (link && !link.classList.contains('menu-toggle')) {
                    link.style.fontWeight = 'bold';
                }
            }
        });
    });
</script>